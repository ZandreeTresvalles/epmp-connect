{
  "manifest_version": 3,
  "name": "EPMP Connect",
  "version": "2.1.0",
  "description": "Captures authenticated Shopee, Lazada, and TikTok Seller Center sessions for EPMP / ReportBot / Audit automation. One shared capture extension for every project.",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "EPMP Connect"
  },
  "permissions": [
    "cookies",
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.shopee.ph/*",
    "*://*.shopee.com/*",
    "*://*.lazada.com.ph/*",
    "*://*.lazada.com/*",
    "*://*.tiktok.com/*",
    "*://*.tiktokshop.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://epmp-orpin.vercel.app/*",
        "https://cloudecomm-encoder-reports-automation.vercel.app/*",
        "https://cloudecomm-audit-reports-automation.vercel.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:39003/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://seller.shopee.ph/*",
        "*://sellercenter.lazada.com.ph/*",
        "*://seller.tiktok.com/*",
        "*://seller-ph.tiktok.com/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}